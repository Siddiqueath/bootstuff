{
  "name": "bootstuff",
  "version": "1.3.0",
  "description": "Launch your entire work environment in one click",
  "main": "src/main/index.js",
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"npm run dev:electron:wait\"",
    "dev:renderer": "cd src/renderer && npm run dev",
    "dev:electron:wait": "wait-on http://localhost:5173 && npm run dev:electron",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build:renderer": "cd src/renderer && npm run build",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir",
    "build:nosign": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File deploy.ps1",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:all": "npm run build:renderer && electron-builder --win portable --mac --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.bootstuff.app",
    "productName": "BootStuff",
    "files": [
      "src/main/**/*",
      "src/renderer/dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "forceCodeSigning": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "author": "Siddiqueath"
}